<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 1.5rem;
    
  }

  .filter {
    min-width: 65px;
    text-align: center;
    opacity: 0.7;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter i {
    font-size: 1.2rem;
  }

  .filter p {
    font-size: 0.8rem;
    margin-top: 0.4rem;
    margin-bottom: 0;
  }
/* Remove link appearance from category icons */
#filters a.filter,
#filters a.filter:link,
#filters a.filter:visited,
#filters a.filter:hover,
#filters a.filter:active,
#filters a.filter:focus {
  color: #222 !important;
  text-decoration: none !important;
  outline: none;
  box-shadow: none;
}

#filters a.filter i,
#filters a.filter p {
  color: inherit !important;
  text-decoration: none !important;
}

#filters a.filter {
  display: block;
  min-width: 65px;
  text-align: center;
  opacity: 0.65;
  border-bottom: 2px solid transparent;
  transition: opacity 0.2s ease;
}

#filters a.filter:hover {
  opacity: 1;
}

/* Selected category */
#filters a.filter.active-filter {
  opacity: 1;
  color: #222 !important;
  border-bottom-color: #222;
}
  /* Remaining categories container */
  .extra-filters {
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .tax-toggle {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 1rem;
    padding: 0.8rem 1rem;
    margin-left: auto;
  }

  .tax-toggle label {
    margin-right: 0.5rem;
    white-space: nowrap;
  }

  /* Hidden on desktop */
  .mobile-filter-button {
    display: none;
  }

  /* On tablet and desktop, always display all categories */
  @media (min-width: 577px) {
    .extra-filters.collapse {
      display: flex !important;
    }
  }

  /* Mobile screen */
  @media (max-width: 576px) {
    #filters {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.2rem 0.5rem;
      width: 100%;
    }

    .filter {
      min-width: 0;
      width: 100%;
    }

    .filter i {
      font-size: 1.15rem;
    }

    .filter p {
      font-size: 0.72rem;
      white-space: normal;
    }

    /* Remaining filters take full width */
    .extra-filters {
      grid-column: 1 / -1;
      width: 100%;
    }

    /* Grid layout when collapse is opened */
    .extra-filters.collapse.show {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.2rem 0.5rem;
    }

    .extra-filters.collapsing {
      grid-column: 1 / -1;
    }

    .tax-toggle {
      grid-column: 1 / -1;
      width: 100%;
      justify-content: center;
      margin-left: 0;
      padding: 0.7rem;
    }

    .tax-toggle label {
      font-size: 0.9rem;
      white-space: normal;
    }

    .mobile-filter-button {
      display: block;
      margin: 1rem auto 0;
      border-radius: 2rem;
      font-size: 0.85rem;
    }

    .mobile-filter-button .show-less-text {
      display: none;
    }

    .mobile-filter-button[aria-expanded="true"] .show-more-text {
      display: none;
    }

    .mobile-filter-button[aria-expanded="true"] .show-less-text {
      display: inline;
    }

  }
  .tax-info{
    display : none;

  }
</style>

<%
  const buildCategoryUrl = (category) => {
    const params = new URLSearchParams();

    if (search) {
      params.set("search", search);
    }

    if (selectedCountry) {
      params.set("country", selectedCountry);
    }

    if (category) {
      params.set("category", category);
    }

    const queryString = params.toString();

    return queryString
      ? `/listings?${queryString}`
      : "/listings";
  };
%>
<!-- Category filters -->
<div id="filters">

  <a
    href="<%= buildCategoryUrl('Trending') %>"
    class="filter <%= selectedCategory === 'Trending' ? 'active-filter' : '' %>"
  >
    <div>
      <i class="fa-solid fa-fire"></i>
    </div>
    <p>Trending</p>
  </a>

  <a
    href="<%= buildCategoryUrl('Rooms') %>"
    class="filter <%= selectedCategory === 'Rooms' ? 'active-filter' : '' %>"
  >
    <div>
      <i class="fa-solid fa-bed"></i>
    </div>
    <p>Rooms</p>
  </a>

  <a
    href="<%= buildCategoryUrl('Iconic Cities') %>"
    class="filter <%= selectedCategory === 'Iconic Cities' ? 'active-filter' : '' %>"
  >
    <div>
      <i class="fa-solid fa-mountain-city"></i>
    </div>
    <p>Iconic Cities</p>
  </a>

  <a
    href="<%= buildCategoryUrl('Mountain') %>"
    class="filter <%= selectedCategory === 'Mountain' ? 'active-filter' : '' %>"
  >
    <div>
      <i class="fa-solid fa-mountain"></i>
    </div>
    <p>Mountain</p>
  </a>

  <div class="collapse extra-filters" id="moreFilters">

    <a
      href="<%= buildCategoryUrl('Castle') %>"
      class="filter <%= selectedCategory === 'Castle' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-brands fa-fort-awesome"></i>
      </div>
      <p>Castle</p>
    </a>

    <a
      href="<%= buildCategoryUrl('Amazing Pools') %>"
      class="filter <%= selectedCategory === 'Amazing Pools' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-solid fa-person-swimming"></i>
      </div>
      <p>Amazing Pools</p>
    </a>

    <a
      href="<%= buildCategoryUrl('Camping') %>"
      class="filter <%= selectedCategory === 'Camping' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-solid fa-campground"></i>
      </div>
      <p>Camping</p>
    </a>

    <a
      href="<%= buildCategoryUrl('Farms') %>"
      class="filter <%= selectedCategory === 'Farms' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-solid fa-truck-field"></i>
      </div>
      <p>Farms</p>
    </a>

    <a
      href="<%= buildCategoryUrl('Arctic') %>"
      class="filter <%= selectedCategory === 'Arctic' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-solid fa-snowman"></i>
      </div>
      <p>Arctic</p>
    </a>

    <a
      href="<%= buildCategoryUrl('Dome') %>"
      class="filter <%= selectedCategory === 'Dome' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-solid fa-landmark-dome"></i>
      </div>
      <p>Dome</p>
    </a>

    <a
      href="<%= buildCategoryUrl('Boat') %>"
      class="filter <%= selectedCategory === 'Boat' ? 'active-filter' : '' %>"
    >
      <div>
        <i class="fa-solid fa-sailboat"></i>
      </div>
      <p>Boat</p>
    </a>

  </div>



  <!-- Tax toggle -->
  <div class="tax-toggle">
    <div class="form-check form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      >

      <label
        class="form-check-label"
        for="switchCheckDefault"
      >
        Display total after taxes
      </label>
    </div>
  </div>

</div>

<!-- Show more button: only visible on mobile -->
<button
  class="btn btn-outline-dark mobile-filter-button"
  type="button"
  data-bs-toggle="collapse"
  data-bs-target="#moreFilters"
  aria-expanded="false"
  aria-controls="moreFilters"
>
  <span class="show-more-text">
    Show more
    <i class="fa-solid fa-chevron-down"></i>
  </span>

  <span class="show-less-text">
    Show less
    <i class="fa-solid fa-chevron-up"></i>
  </span>
</button>

<% if (allListings.length === 0) { %>
  <div class="alert alert-warning text-center mt-4">
    No listings found

    <% if (search) { %>
      for "<strong><%= search %></strong>"
    <% } %>

    <% if (selectedCountry) { %>
      in <strong><%= selectedCountry %></strong>
    <% } %>
  </div>
<% } %>

<!-- Listing cards -->
<div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 g-4 mt-1">

  <% for (let listing of allListings) { %>

    <div class="col">
      <a
        href="/listings/<%= listing._id %>"
        class="listing-link"
      >

        <div class="card listing-card border-0">

          <img
            src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1552733407-5d5c46c3bb3b?auto=format&fit=crop&w=800&q=60' %>"
            class="card-img-top"
            alt="<%= listing.title %>"
          >

          <div class="card-img-overlay"></div>

          <div class="card-body">
            <h5 class="card-title">
              <%= listing.title %>
            </h5>

            <p class="card-text">
              ₹
              <%= listing.price
                ? listing.price.toLocaleString("en-IN")
                : "N/A"
              %>
              / night
              <i class ="tax-info"> &nbsp;&nbsp; +18% GST</i>
            </p>
          </div>

        </div>
      </a>
    </div>

  <% } %>

</div>

<script>
  const taxSwitch = document.getElementById("switchCheckDefault");

  taxSwitch.addEventListener("change", () => {
    const taxInfo = document.getElementsByClassName("tax-info");

    if (taxSwitch.checked) {
      for (const tax of taxInfo) {
        tax.style.display = "inline";
      }
    } else {
      for (const tax of taxInfo) {
        tax.style.display = "none";
      }
    }
  });
</script>